---
import Clock from "../components/Clock.astro";
import RadioPlayer from "../components/RadioPlayer.astro";
import Chat from "../components/Chat.astro";
import "../styles/main.css";

interface Props {
  title?: string;
}
const { title = "Seyðisfjörður Community Radio" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="robots" content="index,follow" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <script
      is:inline
      src="https://cdn.jsdelivr.net/npm/sp-supermarquee/dist/SuperMarquee.min.js"
    ></script>
  </head>

  <body>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:bg-white focus:text-black focus:px-3 focus:py-1"
    >
      Skip to content
    </a>

    <Chat />

    <header>
      <a
        class="fixed bottom-6 left-6 text-black lg:top-6 lg:bottom-auto lg:text-white"
        href="/"
      >
        <span class="font-serif font-h1 leading-[0.55]"
          >Seyðisfjörður<br />
          Community Radio</span
        ><br />
        <span class="font-p relative -top-1">107.1 FM</span>
      </a>

      <nav
        aria-label="Main navigation"
        class="hidden lg:block fixed bottom-6 left-6 text-white font-h1"
      >
        <ul class="space-y-1">
          <li><a href="#about">About</a></li>
          <li><a href="#archive">Archive</a></li>
          <li><a href="#newsletter">Newsletter</a></li>
          <li><a href="#schedule">Schedule</a></li>
          <li><a href="#chat" data-chat-open>Chat</a></li>
        </ul>
      </nav>

      <RadioPlayer />
      <Clock />
    </header>

    <main id="main-content">
      <slot />
    </main>
  </body>
</html>
